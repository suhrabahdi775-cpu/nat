# Exchange API Keys
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# AI Service API Keys
DEEPSEEK_API_KEY=

# Sentiment data (CryptoOracle) - required for sentiment integration
CRYPTORACLE_API_KEY=

# Optional: If you need OKX for reference or testing
OKX_API_KEY=
OKX_SECRET=
OKX_PASSWORD=

# Strategy Parameters (override YAML config)
EQUITY=500                       # Fallback capital in USDT (live balance used when USE_ACCOUNT_BALANCE=true)
LEVERAGE=10                      # Position leverage (1-125)
BASE_POSITION_USDT=100           # Base position notional in USDT

# Position Sizing
SIZING_MODE=risk                 # risk = fixed % of equity risked at the stop (recommended)
                                 #        | notional = legacy fixed base_usdt × multipliers
RISK_PER_TRADE_PCT=0.01          # (risk mode) 1% of equity risked at the stop for MEDIUM conf
                                 #   scaled by confidence (HIGH 1.5x), trend (1.2x), RSI, streak
MAX_POSITION_RATIO=0.20          # Max % of equity as MARGIN per position (backstop cap).
                                 #   In risk mode a tight stop yields a big position - this
                                 #   caps it. 0.20 = up to 20% of equity as margin per trade.
BASE_POSITION_USDT=100           # (notional mode only) base notional per trade
HIGH_CONFIDENCE_MULTIPLIER=1.5
MEDIUM_CONFIDENCE_MULTIPLIER=1.0
LOW_CONFIDENCE_MULTIPLIER=0.5
TREND_STRENGTH_MULTIPLIER=1.2
USE_ACCOUNT_BALANCE=true         # Size from live account balance (fallback: EQUITY)

# Trading Parameters
TIMEFRAME=15m                    # Bar interval (5m, 15m, 1h, etc.)
ANALYSIS_SOURCE=rest             # rest = poll Binance REST klines (reliable, recommended)
                                 #   | websocket = event-driven on the pushed kline stream
ANALYZE_ON_BAR_CLOSE=true        # (websocket mode only) analyze on each closed bar
TIMER_INTERVAL_SEC=900           # REST poll / timer interval in seconds (900 = 15 min)
MIN_CONFIDENCE_TO_TRADE=MEDIUM   # LOW, MEDIUM, HIGH

# Stop Loss / Take Profit (ATR-based; OOS-validated defaults July 2026)
ATR_SL_MULTIPLIER=1.5            # SL distance = 1.5 x ATR
MIN_SL_PCT=0.003                 # SL floor: 0.3% of entry
MAX_SL_PCT=0.015                 # SL cap: 1.5% of entry
MIN_RISK_REWARD=1.5              # (confidence_pct mode) TP >= 1.5 x SL distance
TP_MODE=r_multiple               # r_multiple | confidence_pct
TP_R_MULTIPLE=1.0                # TP = 1.0 x SL distance (higher win-rate profile)

# Filters & Circuit Breakers
ENABLE_HTF_FILTER=true           # 1h trend filter
HTF_STRICT_ALIGNMENT=true        # Entries must be WITH the 1h trend
LOSS_COOLDOWN_BARS=2             # No new entries for N bars after a loss
LOSS_STREAK_THRESHOLD=2          # Halve size after N consecutive losses
DAILY_LOSS_LIMIT_PCT=0.05        # Halt new entries after -5% realized day PnL
MAX_POSITION_AGE_BARS=24         # Close stagnant positions after N bars
REVERSAL_CONFIRMATION_SIGNALS=2  # Consecutive opposite signals required to reverse
MIN_ATR_PCT_TO_TRADE=0.001       # Skip entries when ATR < 0.1% of price
ENABLE_BREAKEVEN_STOP=true       # Move SL to entry at 1R profit

# Live Safety
CLOSE_POSITIONS_ON_STOP=true     # Flatten on stop (emulated SL/TP die with the bot)
USE_ORDER_EMULATION=true         # false = native venue stops (survive crashes; validate first)

# Testing (NOTE: these do NOT prevent real orders - main_live.py always trades live)
TEST_MODE=false                  # Only affects the startup confirmation prompt
DRY_RUN=false                    # Not wired to order execution
AUTO_CONFIRM=false               # true = skip the startup yes/no prompt

# Logging
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/deepseek_strategy.log

# Monitoring
ENABLE_TELEGRAM=false            # Env takes precedence over YAML
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
